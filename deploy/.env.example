# ================================================================
# 目标服务器专用环境变量模板。
# 首次部署前: cp .env.example .env
# ================================================================

# ---- Compose project ----
COMPOSE_PROJECT_NAME=gpt2api
APP_BASE_DIR=/opt/gpt2api

# ---- Docker network ----
# 1Panel 系统一般自带 1panel-network,适合给站点反代和应用商店容器共用。
APP_NETWORK_NAME=1panel-network
APP_NETWORK_EXTERNAL=true

# ---- Docker Hub ----
# 工作流部署时会临时注入这两个值;手动部署时也可以直接在 .env 中指定。
DOCKERHUB_IMAGE=docker.io/yourname/gpt2api
IMAGE_TAG=latest

# ---- MySQL ----
MYSQL_HOST=mysql
MYSQL_USER=gpt2api
MYSQL_PASSWORD=please_change_me
MYSQL_DATABASE=gpt2api
MYSQL_PORT=3306
MYSQL_DSN_PARAMS=parseTime=true&loc=Local&charset=utf8mb4&collation=utf8mb4_unicode_ci

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=please_change_me
REDIS_DB=0

# ---- Server ----
HTTP_BIND_HOST=127.0.0.1
HTTP_PORT=8080

# ---- Security (生产强制改!) ----
JWT_SECRET=please_change_to_a_32_character_random_string_abcdef
CRYPTO_AES_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ---- Backup ----
BACKUP_RETENTION=30
BACKUP_ALLOW_RESTORE=false

# ---- DNS ----
DNS_PRIMARY=8.8.8.8
DNS_FALLBACK=1.1.1.1
