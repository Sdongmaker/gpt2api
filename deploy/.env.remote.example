# ================================================================
# 目标服务器专用环境变量模板。
# 首次部署前: cp .env.example .env
# ================================================================

# ---- Compose project ----
COMPOSE_PROJECT_NAME=gpt2api
APP_BASE_DIR=/opt/gpt2api

# ---- Docker Hub ----
# 工作流部署时会临时注入这两个值;手动部署时也可以直接在 .env 中指定。
DOCKERHUB_IMAGE=docker.io/yourname/gpt2api
IMAGE_TAG=latest

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=please_change_me_root
MYSQL_USER=gpt2api
MYSQL_PASSWORD=please_change_me
MYSQL_DATABASE=gpt2api
MYSQL_PORT=3306

# ---- Redis ----
REDIS_PORT=6379

# ---- Server ----
HTTP_PORT=8080

# ---- Security (生产强制改!) ----
JWT_SECRET=please_change_to_a_32_character_random_string_abcdef
CRYPTO_AES_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ---- Backup ----
BACKUP_RETENTION=30
BACKUP_ALLOW_RESTORE=false

# ---- DNS ----
DNS_PRIMARY=8.8.8.8
DNS_FALLBACK=1.1.1.1
